{
  "sftp": {
    "host": "your-sftp-server.example.com",
    "port": 22,
    "username": "sync-user",
    "authMethod": "key",
    "privateKeyPath": "/path/to/private/key",
    "timeout": 30000,
    "retryAttempts": 3
  },
  "workspace": {
    "basePath": "./workspace"
  },
  "sync": {
    "autoCommit": false,
    "commitMessageTemplate": "Auto sync: {timestamp}"
  }
}
