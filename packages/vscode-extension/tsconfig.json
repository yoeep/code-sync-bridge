{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2020"],
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@code-sync-bridge/shared": [
        "../shared/src"
      ],
      "@code-sync-bridge/shared/types": [
        "../shared/src/types"
      ],
      "@code-sync-bridge/shared/interfaces": [
        "../shared/src/interfaces"
      ],
      "@code-sync-bridge/shared/config": [
        "../shared/src/config"
      ],
      "@code-sync-bridge/shared/runtime": [
        "../shared/src/runtime"
      ],
      "@code-sync-bridge/shared/utils/Logger": [
        "../shared/src/utils/Logger"
      ],
      "@code-sync-bridge/shared/sftp": [
        "../shared/src/sftp"
      ],
      "@code-sync-bridge/extranet-client": [
        "../extranet-client/src"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "references": [
    { "path": "../shared" },
    { "path": "../extranet-client" }
  ]
}
