      "types": "./dist/security/FileIntegrityChecker.d.ts",
      "default": "./dist/security/FileIntegrityChecker.js"
    },
    "./security/TransferEncryption": {
      "types": "./dist/security/TransferEncryption.d.ts",
      "default": "./dist/security/TransferEncryption.js"
    },
    "./transfer/ResumableTransfer": {
      "types": "./dist/transfer/ResumableTransfer.d.ts",
      "default": "./dist/transfer/ResumableTransfer.js"
    },
    "./conflict/ConflictResolver": {
      "types": "./dist/conflict/ConflictResolver.d.ts",
      "default": "./dist/conflict/ConflictResolver.js"
    },
    "./conflict/ConflictNotificationManager": {
      "types": "./dist/conflict/ConflictNotificationManager.d.ts",
      "default": "./dist/conflict/ConflictNotificationManager.js"
    },
    "./performance/PerformanceMonitor": {
      "types": "./dist/performance/PerformanceMonitor.d.ts",
      "default": "./dist/performance/PerformanceMonitor.js"
    },
    "./performance/LargeFileHandler": {
      "types": "./dist/performance/LargeFileHandler.d.ts",
      "default": "./dist/performance/LargeFileHandler.js"
    },
    "./performance/MemoryOptimizer": {
      "types": "./dist/performance/MemoryOptimizer.d.ts",
      "default": "./dist/performance/MemoryOptimizer.js"
    },
    "./performance/PerformanceManager": {
      "types": "./dist/performance/PerformanceManager.d.ts",
      "default": "./dist/performance/PerformanceManager.js"
    }
