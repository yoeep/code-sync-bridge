{
  "name": "@code-sync-bridge/shared",
  "version": "1.0.0",
  "description": "Shared runtime, SFTP, transfer, security, and configuration modules.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code-sync-bridge/code-sync-bridge.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/code-sync-bridge/code-sync-bridge/tree/main/packages/shared",
  "bugs": {
    "url": "https://github.com/code-sync-bridge/code-sync-bridge/issues"
  },
  "keywords": [
    "sftp",
    "sync",
    "shared",
    "typescript",
    "code-sync"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "default": "./dist/interfaces/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./utils/paths": {
      "types": "./dist/utils/paths.d.ts",
      "default": "./dist/utils/paths.js"
    },
    "./utils/Logger": {
      "types": "./dist/utils/Logger.d.ts",
      "default": "./dist/utils/Logger.js"
    },
    "./sftp": {
      "types": "./dist/sftp/index.d.ts",
      "default": "./dist/sftp/index.js"
    },
    "./network/NetworkErrorHandler": {
      "types": "./dist/network/NetworkErrorHandler.d.ts",
      "default": "./dist/network/NetworkErrorHandler.js"
    },
    "./network/NetworkMonitor": {
      "types": "./dist/network/NetworkMonitor.d.ts",
      "default": "./dist/network/NetworkMonitor.js"
